    <s:String
        x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=78495D577D35A34B9E360EEA9D5747D2/Text/@EntryValue">[ValueConversion(typeof(object), typeof(object))] public class $classname$ : TcMarkupExtensionConverterOneWay&lt;$classname$&gt; { /// &lt;summary&gt; /// Converts a value. /// &lt;/summary&gt; /// &lt;param&#xD;                    name="value"&gt;The value produced by the binding source.&lt;/param&gt; /// &lt;param name="targetType"&gt;The type of the binding target property.&lt;/param&gt; /// &lt;param&#xD;                    name="parameter"&gt;The converter parameter to use.&lt;/param&gt; /// &lt;param name="culture"&gt;The culture to use in the converter.&lt;/param&gt; /// &lt;returns&gt; /// The converted value. If the method returns &lt;c&gt;null&lt;/c&gt;, the valid &lt;c&gt;null&lt;/c&gt; value is used. /// &lt;/returns&gt; public override object Convert(object value, Type targetType, object parameter, CultureInfo culture) { if (!ValidateValue(value)) { return null; } throw new NotImplementedException(); } }</s:String>
    <s:Boolean
        x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=78495D577D35A34B9E360EEA9D5747D2/Reformat/@EntryValue">True</s:Boolean>
    <s:Boolean
        x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=78495D577D35A34B9E360EEA9D5747D2/ShortenQualifiedReferences/@EntryValue">True</s:Boolean>
    <s:Boolean
        x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=78495D577D35A34B9E360EEA9D5747D2/Applicability/=Live/@EntryIndexedValue">True</s:Boolean>
    <s:Boolean
        x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=78495D577D35A34B9E360EEA9D5747D2/Scope/=C3001E7C0DA78E4487072B7E050D86C5/@KeyIndexDefined">True</s:Boolean>
    <s:String
