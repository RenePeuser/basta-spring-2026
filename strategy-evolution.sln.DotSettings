        x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=FCC76572B2173B43A0330207029B2C30/Text/@EntryValue">/// &lt;summary&gt; /// Represents the unit test for the &lt;see&#xD;                    cref="$class$" /&gt; /// &lt;/summary&gt; [TestClass] public class $class$Test : TcInvokeTestClassSingleThreadedBase { private $type$ mTestObject; public override void OnTestInitialize() { base.OnTestInitialize(); mTestObject = new $type$($END$); } }</s:String>
