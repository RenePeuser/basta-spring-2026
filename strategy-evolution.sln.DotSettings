        x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=29D6506C85934E43937FAB6D5C5E2E05/Text/@EntryValue">[ValueConversion(typeof(object), typeof(object))] public class $classname$ : TcMarkupExtensionConverter&lt; $classname$&gt; { /// &lt;summary&gt; /// Converts a value. /// &lt;/summary&gt; /// &lt;param&#xD;                    name="value"&gt;The value produced by the binding source.&lt;/param&gt; /// &lt;param name="targetType"&gt;The type of the binding target property.&lt;/param&gt; /// &lt;param&#xD;                    name="parameter"&gt;The converter parameter to use.&lt;/param&gt; /// &lt;param name="culture"&gt;The culture to use in the converter.&lt;/param&gt; /// &lt;returns&gt; /// The converted value. If the method returns &lt;c&gt;null&lt;/c&gt;, the valid &lt;c&gt;null&lt;/c&gt; value is used. /// &lt;/returns&gt; public override object Convert(object value, Type targetType, object parameter, CultureInfo culture) { if (!ValidateValue(value)) { return null; } throw new NotImplementedException(); } /// &lt;summary&gt; /// Converts the value back. /// &lt;/summary&gt; /// &lt;param&#xD;                    name="value"&gt;The value produced by changes on the view.&lt;/param&gt; /// &lt;param name="targetType"&gt;The type of the binding target property.&lt;/param&gt; /// &lt;param&#xD;                    name="parameter"&gt;The converter parameter to use.&lt;/param&gt; /// &lt;param name="culture"&gt;The culture to use in the converter.&lt;/param&gt; /// &lt;returns&gt;The back converted value..&lt;/returns&gt; public override object ConvertBack(object value, Type targetType, object parameter, CultureInfo culture) { throw new NotImplementedException(); } }</s:String>
