        x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=C709908B0FEE5D41B22548853DE80FFF/Text/@EntryValue">private $Type$ m$Name$; public $Type$ $Name$ { get { TcInvoke.CheckAccess(this); return m$Name$; } set { TcInvoke.CheckAccess(this); if (m$Name$.NotEqualsTo(value)) { m$Name$ = value; RaisePropertyChanged(() =&gt; $Name$); } } }</s:String>
