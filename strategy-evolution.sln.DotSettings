    <s:String
                x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=14D96BDE901FCA45A705B5014F666794/Text/@EntryValue">internal static class Add$Domain$DbContextExtension { internal static void Add$Domain$DbContext(this IServiceCollection services) { services.AddSingletonIfNotExists&lt;$Domain&#xD;                    DbContext=""&gt;(); } } public class $Domain$DbContext { private readonly List&lt;$Domain$&gt; _$domain$s = new(); internal IImmutableList&lt;$Domain$&gt; GetAll$Domain$s() { return _$domain$s.ToImmutableList(); } public $Domain$ Add$Domain$($Domain$ request$Domain$) { _$domain$s.Add(request$Domain$); return request$Domain$; } public void DeleteById(long requestId) { var $domain$ToDelete = _$domain$s.FirstOrDefault($domain$ =&gt; $domain$.Id == requestId); if ($domain$ToDelete.IsNull()) { throw new ProblemDetailsException("Expected $domain$ does not exist", $"The $domain$ wiht the id: {requestId} was not found or does not exists", ("$Domain$ Id", requestId.ToInvariantString())); } _$domain$s.Remove($domain$ToDelete); } public void DeleteBy(Func&lt;$Domain&#xD;                    bool=""&gt; $domain$ToDelete) { var $domain$s = _$domain$s.Where($domain$ToDelete).ToList(); _$domain$s.RemoveRange($domain$s); } public void DeleteAll() { _$domain$s.Clear(); } }</s:String>
