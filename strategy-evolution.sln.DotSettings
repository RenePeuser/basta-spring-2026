    <s:String
                x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=6A93F98DB9A422438F749BE6D10EE6EA/Text/@EntryValue">[Authorize] [ApiController] [ApiVersion("1.0")] [Route("$baseurl$")] public class OpportunitiesController : ControllerBase { private readonly IMediator _mediator; public OpportunitiesController(IMediator mediator) { _mediator = mediator; } [HttpPost] [OAuth2Scope("$service$.$entitylower$.write")] [ProducesResponseType(typeof(Add$entity$Response), StatusCodes.Status200OK)] [ProducesResponseType(typeof(ProblemDetails), StatusCodes.Status400BadRequest)] [SwaggerOperation(OperationId = "add-$entity$", Tags = new[] {"$entity$"})] public Task&lt;Add&#xD;                    entity=""$ Response=""&gt; Add$entity$Async($entitylower$ $entitylower$) { return _mediator.SendAsync(new Add$entity$($entitylower$)); } [HttpGet] [OAuth2Scope("$service$.$entity$.read")] [ProducesResponseType(typeof(GetAll$entity$Response), StatusCodes.Status200OK)] [ProducesResponseType(typeof(ProblemDetails), StatusCodes.Status400BadRequest)] [SwaggerOperation(OperationId = "get-all-opportunities", Tags = new[] {"$entity$"})] public Task&lt;GetAll&#xD;                    entity=""$ Response=""&gt; GetAll$entity$sAsync() { return _mediator.SendAsync(new GetAll$entity$s($entitylower$)); } [HttpGet("{idOrNumber}")] [OAuth2Scope("$service$.$entity$.read")] [ProducesResponseType(typeof(Get$entity$ByIdOrNumberResponse), StatusCodes.Status200OK)] [ProducesResponseType(typeof(ProblemDetails), StatusCodes.Status400BadRequest)] [SwaggerOperation(OperationId = "get-opportunity-line-detail-by-id", Tags = new[] {"$entity$"})] public Task&lt;Get&#xD;                    entity=""$ ByIdOrNumberResponse=""&gt; GetOpportunityByIdOrNumberAsync(string id) { return _mediator.SendAsync(new Get$entity$ByIdOrNumber(partner, idOrNumber)); } [HttpDelete("{idOrNumber}")] [OAuth2Scope("$service$.$entity$.delete")] [ProducesResponseType(StatusCodes.Status204NoContent)] [ProducesResponseType(typeof(ProblemDetails), StatusCodes.Status400BadRequest)] [SwaggerOperation(OperationId = "delete-$entity$-by-id", Tags = new[] {"$entity$"})] public async Task&lt;ActionResult&gt; DeleteOpportunityByIdOrNumberAsync(string id) { await _mediator.SendAsync(new Delete$entity$ById(partner, idOrNumber)).ConfigureAwait(false); return NoContent(); } [HttpDelete] [OAuth2Scope("$service$.$entity$.delete")] [ProducesResponseType(typeof(DeleteAllOpportunitiesResponse), StatusCodes.Status200OK)] [ProducesResponseType(typeof(ProblemDetails), StatusCodes.Status400BadRequest)] [SwaggerOperation(OperationId = "delete-all-$entity$", Tags = new[] {"$entity$"})] public Task&lt;DeleteAllOpportunitiesResponse&gt; DeleteAllOpportunitiesAsync(string partner, [FromQuery] string? idOrNumber = null) { return _mediator.SendAsync(new DeleteAll$entity$(partner, idOrNumber)); } }</s:String>
