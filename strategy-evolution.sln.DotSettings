    <s:String
        x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=BB8C7B36E5352E4D909780D078AE2616/Text/@EntryValue">public abstract class SystemTestBase { protected string Output { get; private set; } protected int ExitCode { get; private set; } [TestInitialize] public async Task InitAsync() { BeforeExecution(); await using var sw = new StringWriter(); Console.SetOut(sw); string[] strings = CollectConsoleParameters().ToArray(); ExitCode = await Program.Main(strings); Output = sw.ToString(); AfterExecution(); } protected virtual void BeforeExecution() { } protected abstract IEnumerable&lt;string&gt; CollectConsoleParameters(); protected virtual void AfterExecution() { } }</s:String>
