    <s:String
                x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=1044CC8FEC3A82478EB44FB3E218B818/Text/@EntryValue">private $TestClass$ mTestObject; private TiRemoteObjectWrapper&lt;$RemoteObject$&gt; mRemoteObjectWrapper; private TiGlobalFactoryService mGlobalFactoryService; private TiArgumentService mArgumentService; private TiLogService mLogService; [TestInitialize] public void TestInitialize() { mRemoteObjectWrapper = TcObjectCreator.Create&lt;TiRemoteObjectWrapper&lt;$RemoteObject$&gt;&gt;(); mGlobalFactoryService = TcObjectCreator.Create&lt;TiGlobalFactoryService&gt;(); mArgumentService = TcObjectCreator.Create&lt;TiArgumentService&gt;(); mLogService = TcObjectCreator.Create&lt;TiLogService&gt;(); mTestObject = new $TestClass$(mRemoteObjectWrapper, mGlobalFactoryService, mArgumentService, mLogService); }</s:String>
