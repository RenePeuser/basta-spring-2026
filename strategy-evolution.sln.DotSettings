        x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=F32E54477A75E6419F7CA0843995E644/Text/@EntryValue">/// &lt;summary&gt; /// Represents the constructor unit tests for the type &lt;see&#xD;                    cref="$type$" /&gt;. /// &lt;/summary&gt; [TestClass] public class ConstructorTest { [TestInitialize] public void TestInitialize() { $END$ } }</s:String>
