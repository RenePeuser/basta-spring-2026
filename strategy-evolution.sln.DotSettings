    <s:String
        x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=78495D577D35A34B9E360EEA9D5747D2/Scope/=C3001E7C0DA78E4487072B7E050D86C5/CustomProperties/=minimumLanguageVersion/@EntryIndexedValue">2.0</s:String>
    <s:Boolean
        x:Key="/Default/PatternsAndTemplates/LiveTemplates/Template/=78495D577D35A34B9E360EEA9D5747D2/Field/=classname/@KeyIndexDefined">True</s:Boolean>
    <s:Int64
