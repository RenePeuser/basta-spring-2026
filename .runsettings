<RunSettings>
  <RunConfiguration>
    <!-- Use all available logical cores -->
    <MaxCpuCount>1</MaxCpuCount>
  </RunConfiguration>
  <MSTest>
    <Parallelize>
      <!-- Number of worker threads (0 or omit = defaults to MaxCpuCount). Set explicit if desired. -->
      <Workers>1</Workers>
      <!-- Parallelization scope: ClassLevel or MethodLevel -->
      <Scope>ClassLevel</Scope>
    </Parallelize>
  </MSTest>
</RunSettings>
